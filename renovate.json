{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": ["stanikz"],
  "labels": ["renovate"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "gitAuthor": "Renovate Bot <renovate@example.com>",
  "ignorePaths": [
    "services/**",
    "bootstrap/**"
  ],
  "baseBranches": ["main"],
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "semanticCommits": true,
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "description": "Disable database and cache updates",
      "matchPackagePatterns": [
        "postgres",
        "mysql",
        "redis",
        "mongodb",
        "mariadb",
        "valkey"
      ],
      "enabled": false
    },
    {
      "description": "AI stack updates",
      "matchFileNames": [
        "stacks/ai/**"
      ],
      "branchTopic": "renovate-stacks-ai"
    },
    {
      "description": "DietPi stack updates",
      "matchFileNames": [
        "stacks/dietpi/**"
      ],
      "branchTopic": "renovate-stacks-dietpi"
    },
    {
      "description": "Docker stack updates",
      "matchFileNames": [
        "stacks/docker/**"
      ],
      "branchTopic": "renovate-stacks-docker"
    },
    {
      "description": "Media stack updates",
      "matchFileNames": [
        "stacks/media/**"
      ],
      "branchTopic": "renovate-stacks-media"
    },
    {
      "description": "Stremio stack updates",
      "matchFileNames": [
        "stacks/stremio/**"
      ],
      "branchTopic": "renovate-stacks-stremio"
    },
    {
      "description": "VPS stack updates",
      "matchFileNames": [
        "stacks/vps/**"
      ],
      "branchTopic": "renovate-stacks-vps"
    },
    {
      "description": "Common monitoring updates",
      "matchFileNames": [
        "common/monitoring/**"
      ],
      "branchTopic": "renovate-common-monitoring"
    }
  ],
  "docker-compose": {
    "hostRules": [
      {
        "matchHost": "docker.io",
        "concurrentRequestLimit": 2
      }
    ]
  }
}
