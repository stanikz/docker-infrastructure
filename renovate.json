{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": ["stanikz"],
  "labels": ["renovate"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "gitAuthor": "Renovate Bot <renovate@example.com>",
  "ignorePaths": [
    "services/**",
    "bootstrap/**"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "description": "Disable immich stack updates",
      "matchFileNames": [
        "stacks/ai/immich/**"
      ],
      "enabled": false
    },
    {
      "description": "Disable database and cache updates",
      "enabled": false,
      "matchPackageNames": [
        "/postgres/",
        "/mysql/",
        "/redis/",
        "/mongodb/",
        "/mariadb/",
        "/valkey/"
      ]
    },
    {
      "description": "AI stack updates",
      "matchFileNames": [
        "stacks/ai/**"
      ],
      "branchTopic": "stacks-ai"
    },
    {
      "description": "DietPi stack updates",
      "matchFileNames": [
        "stacks/dietpi/**"
      ],
      "branchTopic": "stacks-dietpi"
    },
    {
      "description": "Docker stack updates",
      "matchFileNames": [
        "stacks/docker/**"
      ],
      "branchTopic": "stacks-docker"
    },
    {
      "description": "Media stack updates",
      "matchFileNames": [
        "stacks/media/**"
      ],
      "branchTopic": "stacks-media"
    },
    {
      "description": "Stremio stack updates",
      "matchFileNames": [
        "stacks/stremio/**"
      ],
      "branchTopic": "stacks-stremio"
    },
    {
      "description": "VPS stack updates",
      "matchFileNames": [
        "stacks/vps/**"
      ],
      "branchTopic": "stacks-vps"
    },
    {
      "description": "Common monitoring updates",
      "matchFileNames": [
        "common/monitoring/**"
      ],
      "branchTopic": "common-monitoring"
    }
  ],
  "docker-compose": {
    "hostRules": [
      {
        "matchHost": "docker.io",
        "concurrentRequestLimit": 2
      }
    ]
  }
}
