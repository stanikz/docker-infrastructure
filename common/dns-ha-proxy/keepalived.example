To make this HA setup work, you need to create a specific keepalived.conf file on each of your two hosts. 
This is what tells one server to be the "Master" and the other to be the "Backup".

1. On Host 1 (MASTER): 
Create the file ${DOCKER_DATA}/keepalived/keepalived.conf

vrrp_instance VI_1 {
    state MASTER
    interface eth0          # IMPORTANT: Change to your host's network adapter name (e.g., eth0, end0)
    virtual_router_id 51    # Must be the same on both hosts
    priority 150            # Higher number = Master
    advert_int 1
    unicast_src_ip 192.168.10.150
    unicast_peer {
      192.168.10.60
    }
    authentication {
        auth_type PASS
        auth_pass YourSecretPasswordHere
    }
    virtual_ipaddress {
        192.168.10.151/24     # IMPORTANT: The Virtual IP for your devices to use (This IP MUST within the DHCP range of the LAN)
    }
}

2. On Host 2 (BACKUP): 
Create the file ${DOCKER_DATA}/keepalived/keepalived.conf

vrrp_instance VI_1 {
    state BACKUP
    interface eth0          # IMPORTANT: Change to your host's network adapter name
    virtual_router_id 51    # Must be the same on both hosts
    priority 100            # Lower number = Backup
    advert_int 1
    unicast_src_ip 192.168.10.60
    unicast_peer {
      192.168.10.150
    }
    authentication {
        auth_type PASS
        auth_pass YourSecretPasswordHere
    }
    virtual_ipaddress {
        192.168.10.151/24     # MUST be identical to the Master's Virtual IP (This IP MUST within the DHCP range of the LAN)
    }
}
